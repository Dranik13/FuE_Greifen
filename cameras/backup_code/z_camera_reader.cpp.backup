#include "camera_reader.hpp"

CameraReader::CameraReader(): context_(1)
                            , socket_(context_, zmq::socket_type::pub) 
{
    loadConfig();
    socket_.bind("tcp://*:5555");

    rs2::context ctx;
    auto devices = ctx.query_devices();
    if (devices.size() == 0) {
        std::cerr << "Keine RealSense Kamera gefunden\n";
        return;
    }

    serial_ = devices[0].get_info(RS2_CAMERA_INFO_SERIAL_NUMBER);

    rs2::config cfg;
    cfg.enable_device(serial_);
    cfg.enable_stream(RS2_STREAM_COLOR, 640, 480, RS2_FORMAT_BGR8, 30);
    cfg.enable_stream(RS2_STREAM_DEPTH, 640, 480, RS2_FORMAT_Z16, 30);

    pipeline_.start(cfg);
    running_ = true;

    std::cout << "Pipeline gestartet für Gerät: " << serial_ << "\n";
}

void CameraReader::loadConfig()
{
    cv::FileStorage fs("config.yml", cv::FileStorage::READ);
    if (!fs.isOpened()) {
        std::cerr << "config.yml not found\n";
        return;
    }

    fs["debug"] >> debug_;

    int x, y, w, h;
    fs["roi"]["x"] >> x;
    fs["roi"]["y"] >> y;
    fs["roi"]["width"] >> w;
    fs["roi"]["height"] >> h;
    roi_ = cv::Rect(x, y, w, h);

    fs["conveyor_z_dist"] >> conveyor_z_dist_;
    fs["min_obj_height"] >> min_obj_height_;
    fs["z_offset"] >> z_offset_;

    fs["ref_pt"]["x"] >> ref_pt_.x;
    fs["ref_pt"]["y"] >> ref_pt_.y;

    fs["pos_tol"] >> pos_delta_;  
    fs["size_tol"] >> size_delta_;
    fs["orientation_tol"] >> orientation_delta_;

    canny_thresh_.resize(2);
    fs["canny_thresh1"] >> canny_thresh_.at(0);
    fs["canny_thresh2"] >> canny_thresh_.at(1);

    std::cout << "Config loaded: ROI=" << roi_ << "\n";
}

cv::Point3f CameraReader::computeCenter(const std::vector<cv::Point3f>& corners)
{
    cv::Point3f c(0.f, 0.f, 0.f);
    for (const auto& p : corners) {
        c.x += p.x;
        c.y += p.y;
        c.z += p.z;
    }
    float n = static_cast<float>(corners.size());
    return cv::Point3f(c.x / n, c.y / n, c.z / n);
}

float CameraReader::computeOrientation2D(const std::vector<cv::Point3f>& corners)
{
    const cv::Point3f& p0 = corners[0];
    const cv::Point3f& p1 = corners[1];
    float dx = p1.x - p0.x;
    float dy = p1.y - p0.y;
    return std::atan2(dy, dx);
}

bool CameraReader::checkIfObjIsInList(const Object3D& new_obj, size_t& id)
{
    id = 0;
    for (const auto& obj : obj_list_)
    {
        // check position
        float dx = std::abs(obj.x - new_obj.x);
        float dy = std::abs(obj.y - new_obj.y);
        float dz = std::abs(obj.z - new_obj.z);

        if (dx > pos_delta_ || dy > pos_delta_ || dz > pos_delta_)
        {
            id++;
            continue;
        }
        // // check size
        // float dw = std::abs(obj.width  - new_obj.width);
        // float dl = std::abs(obj.length - new_obj.length);
        // float dh = std::abs(obj.height - new_obj.height);

        // if (dw > size_tol_ || dl > size_tol_ || dh > size_tol_){
        //     id++;
        //     continue;
        // }
        // float dtheta = std::abs(obj.orientation - new_obj.orientation);
        // if (dtheta > orientation_tol_) {
        //     id++;
        //     continue;
        // }
        return true;
    }
    return false;
}

void CameraReader::sendObjList()
{
    Objects3D_msg list;

    for (const auto& obj : obj_list_) {
        auto* o = list.add_objects();
        o->set_x(obj.x);
        o->set_y(obj.y);
        o->set_z(obj.z);
        o->set_orientation(obj.orientation);
        o->set_width(obj.width);
        o->set_length(obj.length);
        o->set_height(obj.height);
        o->set_label(obj.label);
    }

    std::string buffer;
    list.SerializeToString(&buffer);

    zmq::message_t msg(buffer.size());
    memcpy(msg.data(), buffer.data(), buffer.size());
    socket_.send(msg, zmq::send_flags::none);
}

void CameraReader::processFrames() 
{
    // obj_list_.clear();
    try {
        rs2::frameset frames = pipeline_.wait_for_frames(1000);
        rs2::align align_to_color(RS2_STREAM_COLOR);
        auto aligned_frames = align_to_color.process(frames);
        rs2::depth_frame depth = aligned_frames.get_depth_frame();
        rs2::video_frame color = aligned_frames.get_color_frame();

        if (!depth || !color) return;

        // --- Safety: clamp ROI and validate mats ---
        cv::Mat input_img(cv::Size(color.get_width(), color.get_height()), CV_8UC3,
                                  (void*)color.get_data(), cv::Mat::AUTO_STEP);
        
        if (input_img.empty()) return;

        cv::imshow("Input img" + serial_, input_img);

        cv::Mat rgb_img = input_img(roi_).clone();
        
        cv::Mat bgr_img;
        cv::cvtColor(rgb_img, bgr_img, cv::COLOR_RGB2BGR);

        // Depth processing
        cv::Mat depth_mat(cv::Size(depth.get_width(), depth.get_height()), CV_16U,
                            (void*)depth.get_data(), cv::Mat::AUTO_STEP);

        if (depth_mat.empty()) return;

        cv::Mat depth_roi = depth_mat(roi_).clone();

        auto depth_intrinsics = depth.get_profile()
                                    .as<rs2::video_stream_profile>()
                                    .get_intrinsics();

        // --- Berechne ref_pt_ 3D Position einmalig (stationäre Kamera) ---
        if (!ref_pt_3d_.x)
        {
            float d_m = depth.get_distance(static_cast<int>(ref_pt_.x), static_cast<int>(ref_pt_.y));
            if (d_m > 0.0f) 
            {
                float pixel[2] = { static_cast<float>(ref_pt_.x),
                                    static_cast<float>(ref_pt_.y) };

                float pos[3];
                rs2_deproject_pixel_to_point(pos, &depth_intrinsics, pixel, d_m);
                ref_pt_3d_ = cv::Point3f(pos[0], pos[1], pos[2]); // m
                if (debug_) 
                {
                    std::cout << "Reference point 3D (m): X=" << ref_pt_3d_.x 
                                << " Y=" << ref_pt_3d_.y << " Z=" << ref_pt_3d_.z << "\n";
                }
            } else {
                std::cerr << "Warning: Invalid depth at ref_pt\n";
            }
        }

        // Create mask
        cv::Mat obj_mask = cv::Mat::zeros(depth_roi.rows, depth_roi.cols, CV_8U);

        for (int y = 0; y < depth_roi.rows; ++y) {
            for (int x = 0; x < depth_roi.cols; ++x) {
                int total_x = roi_.x + x;
                int total_y = roi_.y + y;
                float depth_value_mm = depth.get_distance(total_x, total_y) * 1000.0f;

                if (depth_value_mm == 0) continue;

                float pixel[2] = { static_cast<float>(total_x), static_cast<float>(total_y) };
                float point[3];
                rs2_deproject_pixel_to_point(point, &depth_intrinsics, pixel, depth_value_mm);

                float z_mm = point[2];

                if (z_mm < conveyor_z_dist_ - min_obj_height_) {
                    obj_mask.at<uint8_t>(y, x) = 255;
                }
            }
        }
        cv::GaussianBlur(obj_mask, obj_mask, cv::Size(5,5), 1.4);
        cv::Canny(obj_mask, obj_mask, canny_thresh_.at(0), canny_thresh_.at(1));

        std::vector<std::vector<cv::Point>> obj_contours;
        cv::findContours(obj_mask, obj_contours, cv::RETR_EXTERNAL, cv::CHAIN_APPROX_SIMPLE);

        // Process contours
        for (size_t ci = 0; ci < obj_contours.size(); ++ci) {
            const auto &cnt = obj_contours[ci];
            if (cv::contourArea(cnt) < 200.0) continue;

            cv::RotatedRect rrect = cv::minAreaRect(cnt);
            cv::Point2f box2f[4];
            rrect.points(box2f);

            std::vector<cv::Point3f> corners3d(4);
            for (int k = 0; k < 4; ++k) {
                int px_roi = std::lround(box2f[k].x);
                int py_roi = std::lround(box2f[k].y);
                int px = roi_.x + px_roi;
                int py = roi_.y + py_roi;
                
                if (px < 0 || py < 0 || px >= depth.get_width() || py >= depth.get_height()) {
                    corners3d[k] = cv::Point3f(NAN, NAN, NAN);
                    continue;
                }

                float d = depth.get_distance(px, py);
                if (d <= 0.0f) {
                    corners3d[k] = cv::Point3f(NAN, NAN, NAN);
                    continue;
                }

                float pixel[2] = { static_cast<float>(px), static_cast<float>(py) };
                float pos[3];
                rs2_deproject_pixel_to_point(pos, &depth_intrinsics, pixel, d);
                corners3d[k] = cv::Point3f(pos[0], pos[1], pos[2]);
            }

            Object3D object;
            cv::Point3f obj_center = computeCenter(corners3d);
            object.x = (obj_center.x - ref_pt_3d_.x) * 1000;  // [mm]
            object.y = (obj_center.y - ref_pt_3d_.y) * 1000;  // [mm]
            object.orientation = computeOrientation2D(corners3d);

            auto dist_mm = [](const cv::Point3f& A, const cv::Point3f& B)->float {
                if (!std::isfinite(A.x) || !std::isfinite(B.x)) return NAN;
                float dx = A.x - B.x, dy = A.y - B.y, dz = A.z - B.z;
                return std::sqrt(dx*dx + dy*dy + dz*dz) * 1000.0f;
            };

            float length_mm = dist_mm(corners3d[0], corners3d[1]);
            float width_mm = dist_mm(corners3d[1], corners3d[2]);
            if (length_mm < width_mm) std::swap(length_mm, width_mm);

            // Height calculation
            cv::Mat mask_roi = cv::Mat::zeros(obj_mask.size(), CV_8U);
            cv::drawContours(mask_roi, std::vector<std::vector<cv::Point>>{cnt}, -1, 255, cv::FILLED);
            
            float sum_z_mm = 0.0f;
            size_t count_z = 0;
            for (size_t y = 0; y < mask_roi.rows; ++y) {
                for (size_t x = 0; x < mask_roi.cols; ++x) {
                    if (mask_roi.at<uint8_t>(y, x) == 0) continue;

                    int px = roi_.x + x;
                    int py = roi_.y + y;
                    float d = depth.get_distance(px, py);

                    if (d <= 0.0f) continue;

                    float pixel[2] = { static_cast<float>(px), static_cast<float>(py) };
                    float pos[3];
                    rs2_deproject_pixel_to_point(pos, &depth_intrinsics, pixel, d);

                    float z_mm = pos[2] * 1000.0f;
                    sum_z_mm += z_mm;
                    count_z++;
                }
            }

            float height_mm = NAN;
            if (count_z > 0) {
                float z_mm = sum_z_mm / static_cast<float>(count_z);
                height_mm = conveyor_z_dist_ - z_mm + 20;
            }

            object.z = (obj_center.z - ref_pt_3d_.z) * 1000 + (height_mm/2);  // [mm]
            object.length = length_mm;
            object.width = width_mm;
            object.height = height_mm;

            // Skip objects with Z > 60 mm
            if (std::isfinite(object.z) && object.z > 60.0f) {
                if (debug_) {
                    std::cout << "Skipping object with z=" << object.z << " mm (> 60 mm)" << std::endl;
                }
                continue;
            }

            size_t id;
            if (checkIfObjIsInList(object, id))
            {
                obj_list_.at(id) = object;
            }
            else 
                obj_list_.push_back(object);

            sendObjList();

            if (debug_) {
                std::cout << "Object " << ci << ": L=" << object.length << "mm W=" << object.width
                            << "mm H=" << object.height << "mm    x:" << object.x << "mm y:" << object.y << "mm z:" << object.z << "mm \n";

                std::cout << "listsize: " << obj_list_.size() << std::endl;
                std::vector<cv::Point> poly;
                for (int k = 0; k < 4; ++k) {
                    poly.emplace_back(std::lround(box2f[k].x), std::lround(box2f[k].y));
                }
                cv::polylines(rgb_img, std::vector<std::vector<cv::Point>>{poly}, true, cv::Scalar(0, 255, 0), 2);
                cv::putText(rgb_img, std::to_string(int(length_mm)) + "mm", poly[0],
                            cv::FONT_HERSHEY_SIMPLEX, 0.6, cv::Scalar(255, 0, 0), 2);
            }
        }

        if (debug_) {
            cv::imshow("Mask - " + serial_, obj_mask);
            cv::imshow("Annotated ROI - " + serial_, rgb_img);
        }

    } catch (const rs2::error &e) {
        std::cerr << "RealSense error for device " << serial_ << ": " << e.what() << "\n";
    } catch (const std::exception &e) {
        std::cerr << "Exception for device " << serial_ << ": " << e.what() << "\n";
    }
}

int main() 
{
    CameraReader reader;

    if (!reader.isRunning()) {
        std::cerr << "CameraReader failed to initialize.\n";
        return 1;
    }

    reader.spin();

    return 0;
}