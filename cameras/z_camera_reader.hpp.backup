#ifndef CAMERA_READER_H
#define CAMERA_READER_H

#include <librealsense2/rs.hpp>
#include <opencv2/opencv.hpp>
#include <opencv2/dnn.hpp>
#include <iostream>
#include <vector>
#include <string>
#include <thread>
#include <chrono>
#include <zmq.hpp>

#include "objects_3D.pb.h"

struct Object3D
{
    float x, y, z;
    float orientation;
    float width, length, height;
    std::string label;
};

/**
 * - get RGB Image and depth information.
 * - detect objects and store their data in buffer of Object3D struct 
 */
class CameraReader {
public:
    CameraReader();

    void spin() {
        while (true) {
            processFrames();

            int key = cv::waitKey(1);
            if (key == 'q' || key == 27) break;
            std::this_thread::sleep_for(std::chrono::milliseconds(5));
        }
    }

    const std::vector<Object3D>& getObjects() const {
        return obj_list_;
    }

    bool isRunning() const {
        return running_;
    }

private:
    bool running_ = false;
    // Config parameters
    bool debug_;
    cv::Rect roi_;
    uint16_t conveyor_z_dist_;
    uint16_t min_obj_height_;
    uint16_t z_offset_;
    std::vector<double> canny_thresh_;
    // refference point in input image (no crop!) for extrinsic claibration
    cv::Point2i ref_pt_;
    cv::Point3f ref_pt_3d_;
    // tolerances for Object list
    float pos_delta_;  
    float size_delta_;
    float orientation_delta_;

    // RealSense
    rs2::pipeline pipeline_;
    std::string serial_;
    rs2::context ctx_;

    // Output
    std::vector<Object3D> obj_list_;
    zmq::context_t context_;
    zmq::socket_t socket_;


    void loadConfig();
    cv::Point3f computeCenter(const std::vector<cv::Point3f>& corners);
    float computeOrientation2D(const std::vector<cv::Point3f>& corners);
    void processFrames();
    bool checkIfObjIsInList(const Object3D& new_obj, size_t& id);
    void sendObjList();
};


#endif // CAMERA_READER_H