	cd /home/tetripick/UR10_Pick_ws/ros2_ws/build/industrial_calibration && $(CMAKE_COMMAND) -S$(CMAKE_SOURCE_DIR) -B$(CMAKE_BINARY_DIR) --check-build-system CMakeFiles/Makefile.cmake 0
