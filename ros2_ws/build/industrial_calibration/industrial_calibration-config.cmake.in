# Default *-config.cmake file created by ros-industrial-cmake-boilerplate

@PACKAGE_INIT@

set(@PROJECT_NAME@_FOUND ON)

# These variables are needed so catkin packages can be located. 
if (EXISTS "@PACKAGE_PREFIX_DIR@/include")
  set(@PROJECT_NAME@_INCLUDE_DIRS "@PACKAGE_PREFIX_DIR@/include")
else()
  set(@PROJECT_NAME@_INCLUDE_DIRS)
endif()
set(@PROJECT_NAME@_LIBRARIES)

# Components
set(@PROJECT_NAME@_SUPPORTED_COMPONENTS core optimizations analysis target_finders_opencv gui examples)
if (NOT @PROJECT_NAME@_FIND_COMPONENTS)
  foreach(component ${@PROJECT_NAME@_SUPPORTED_COMPONENTS})
    include(${CMAKE_CURRENT_LIST_DIR}/${component}-config.cmake)
  endforeach()

  set(@PROJECT_NAME@_LIBRARIES)
  foreach(component ${@PROJECT_NAME@_SUPPORTED_COMPONENTS})
    list(APPEND @PROJECT_NAME@_LIBRARIES ${@PROJECT_NAME@_${component}_LIBRARIES})
  endforeach()
else()
  foreach(component ${@PROJECT_NAME@_FIND_COMPONENTS})
    if(NOT component IN_LIST @PROJECT_NAME@_SUPPORTED_COMPONENTS)
      set(@PROJECT_NAME@_${component}_FOUND OFF)
      set(@PROJECT_NAME@_${component}_NOT_FOUND_MESSAGE "Unsupported component")
      if (@PROJECT_NAME@_FIND_REQUIRED_${component})
        message(FATAL_ERROR "Project ${PROJECT_NAME}, failed to find required component ${component} for package @PROJECT_NAME@. Supported components are: ${@PROJECT_NAME@_SUPPORTED_COMPONENTS}")
      endif()
    else()
      include(${CMAKE_CURRENT_LIST_DIR}/${component}-config.cmake)
    endif()
  endforeach()

  set(@PROJECT_NAME@_LIBRARIES)
  foreach(component ${@PROJECT_NAME@_FIND_COMPONENTS})
    if(component IN_LIST @PROJECT_NAME@_SUPPORTED_COMPONENTS)
      list(APPEND @PROJECT_NAME@_LIBRARIES ${@PROJECT_NAME@_${component}_LIBRARIES})
    endif()
  endforeach()
endif()

